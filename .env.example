# Pereira Tech Talks Dynamics — environment template.
#
# Copy this file to `.env` (gitignored) and fill real values.
# README.md → "Supabase setup" walks through where to get each one.
#
# ────────────────────────────────────────────────────────────────────
# Two distinct trust boundaries live in this file. Keep them separate.
# ────────────────────────────────────────────────────────────────────

# ─── Public client config — shipped inside the KMP app ──────────────
# Used ONLY by composeApp via BuildKonfig (commonMain). RLS is the
# gate that makes shipping these keys safe. Tighten RLS before going
# to production — see supabase/migrations/001_init.sql.
#
# IMPORTANT: SUPABASE_URL must be the base project URL, NOT the REST
# endpoint. The Supabase SDK appends /rest/v1, /auth/v1, /realtime/v1,
# /storage/v1 on its own.
#   correct  → https://abcxyz.supabase.co
#   wrong    → https://abcxyz.supabase.co/rest/v1/
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-key

# ─── Local CLI / migrations only — NEVER ship in clients ────────────
# Used by scripts/supabase_apply.sh and the Supabase CLI.
# Do not reference these from commonMain, app resources, or any code
# that is bundled into a release artifact.
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=replace-with-your-personal-access-token
SUPABASE_DB_PASSWORD=replace-with-your-db-password

# Direct Postgres URL. Use this OR (PROJECT_REF + DB_PASSWORD) — the
# helper script accepts either. Example:
#   postgresql://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=
