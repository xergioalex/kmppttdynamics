TEAM_ID=

PRODUCT_NAME=KMPTodoApp
PRODUCT_BUNDLE_IDENTIFIER=com.xergioalex.kmptodoapp$(TEAM_ID)

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0

// SQLDelight's NativeSqliteDriver calls into libsqlite3, which is a system
// library on iOS. Because ComposeApp is a STATIC framework, linkerOpts in the
// Kotlin build don't propagate to Xcode — we add the flag here so the iosApp
// target's linker resolves _sqlite3_* symbols.
OTHER_LDFLAGS = $(inherited) -lsqlite3